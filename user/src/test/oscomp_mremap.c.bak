#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/mman.h>
#include <string.h>

/*
 * Curated syscall test: mremap
 *
 * Expected: mremap can expand and shrink mappings
 */

static void test_mremap_expand(void)
{
        TEST_START(__func__);

        void *addr, *new_addr;
        int *ptr;
        int i;

        /* Map 2 pages */
        addr = mmap(NULL, 4096 * 2, PROT_READ | PROT_WRITE,
                   MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);

        if (addr == MAP_FAILED) {
                printf("Initial mmap failed!\n");
                TEST_END(__func__);
                exit(1);
        }

        printf("Initial mapping: %p (2 pages)\n", addr);

        /* Write pattern to original area */
        ptr = (int *)addr;
        for (i = 0; i < 2 * 1024; i++) {
                ptr[i] = i;
        }

        /* Expand to 4 pages */
        new_addr = mremap(addr, 4096 * 2, 4096 * 4, 0);

        if (new_addr == MAP_FAILED) {
                printf("mremap failed!\n");
                munmap(addr, 4096 * 2);
                TEST_END(__func__);
                exit(1);
        }

        printf("Expanded mapping: %p (4 pages)\n", new_addr);

        /* Verify old data is still there */
        ptr = (int *)new_addr;
        for (i = 0; i < 2 * 1024; i++) {
                if (ptr[i] != i) {
                        printf("Data mismatch after mremap at index %d\n", i);
                        munmap(new_addr, 4096 * 4);
                        TEST_END(__func__);
                        exit(1);
                }
        }

        /* Write to new area */
        for (i = 2 * 1024; i < 4 * 1024; i++) {
                ptr[i] = i;
        }

        /* Verify new area */
        for (i = 2 * 1024; i < 4 * 1024; i++) {
                if (ptr[i] != i) {
                        printf("Data mismatch in new area at index %d\n", i);
                        munmap(new_addr, 4096 * 4);
                        TEST_END(__func__);
                        exit(1);
                }
        }

        printf("mremap expand test: PASSED\n");

        /* Clean up */
        munmap(new_addr, 4096 * 4);

        TEST_END(__func__);
}

static void test_mremap_shrink(void)
{
        TEST_START(__func__);

        void *addr, *new_addr;
        int *ptr;
        int i;

        /* Map 4 pages */
        addr = mmap(NULL, 4096 * 4, PROT_READ | PROT_WRITE,
                   MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);

        if (addr == MAP_FAILED) {
                printf("Initial mmap failed!\n");
                TEST_END(__func__);
                exit(1);
        }

        printf("Initial mapping: %p (4 pages)\n", addr);

        /* Write pattern */
        ptr = (int *)addr;
        for (i = 0; i < 4 * 1024; i++) {
                ptr[i] = 0xABCD1234 + i;
        }

        /* Shrink to 2 pages */
        new_addr = mremap(addr, 4096 * 4, 4096 * 2, 0);

        if (new_addr == MAP_FAILED) {
                printf("mremap shrink failed!\n");
                munmap(addr, 4096 * 4);
                TEST_END(__func__);
                exit(1);
        }

        printf("Shrunk mapping: %p (2 pages)\n", new_addr);

        /* Verify data in remaining area */
        ptr = (int *)new_addr;
        for (i = 0; i < 2 * 1024; i++) {
                if (ptr[i] != 0xABCD1234 + i) {
                        printf("Data mismatch after shrink at index %d\n", i);
                        munmap(new_addr, 4096 * 2);
                        TEST_END(__func__);
                        exit(1);
                }
        }

        printf("mremap shrink test: PASSED\n");

        /* Clean up */
        munmap(new_addr, 4096 * 2);

        TEST_END(__func__);
}

static void test_mremap_move(void)
{
        TEST_START(__func__);

        void *addr, *new_addr;
        int *ptr;

        /* Map 2 pages at a specific address if possible */
        addr = mmap(NULL, 4096 * 2, PROT_READ | PROT_WRITE,
                   MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);

        if (addr == MAP_FAILED) {
                printf("Initial mmap failed!\n");
                TEST_END(__func__);
                exit(1);
        }

        printf("Initial mapping: %p\n", addr);

        /* Write signature */
        ptr = (int *)addr;
        ptr[0] = 0xFEEDFACE;
        ptr[1024] = 0xBAADF00D;

        /* Try to remap with MREMAP_MAYMOVE */
        new_addr = mremap(addr, 4096 * 2, 4096 * 4, MREMAP_MAYMOVE);

        if (new_addr == MAP_FAILED) {
                printf("mremap with MAYMOVE failed!\n");
                munmap(addr, 4096 * 2);
                TEST_END(__func__);
                exit(1);
        }

        printf("Remapped to: %p (4 pages, may have moved)\n", new_addr);

        /* Verify data */
        ptr = (int *)new_addr;
        if (ptr[0] != 0xFEEDFACE || ptr[1024] != 0xBAADF00D) {
                printf("Data corrupted after mremap!\n");
                munmap(new_addr, 4096 * 4);
                TEST_END(__func__);
                exit(1);
        }

        printf("mremap move test: PASSED\n");

        /* Clean up */
        munmap(new_addr, 4096 * 4);

        TEST_END(__func__);
}

int main(void)
{
        test_mremap_expand();
        test_mremap_shrink();
        test_mremap_move();

        printf("All mremap tests PASSED!\n");

        return 0;
}

#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/mman.h>
#include <string.h>
#include <setjmp.h>
#include <signal.h>

/*
 * Curated syscall test: mprotect
 *
 * Expected: mprotect changes page permissions correctly
 * Note: This test will trigger a SIGSEGV when trying to write to read-only memory
 */

static sigjmp_buf jump_buffer;

static void sigsegv_handler(int sig)
{
        (void)sig;
        siglongjmp(jump_buffer, 1);
}

static void test_mprotect_read_only(void)
{
        TEST_START(__func__);

        void *addr;
        volatile int *ptr;
        int ret;

        /* Set up signal handler for SIGSEGV */
        signal(SIGSEGV, sigsegv_handler);

        /* Map a page with RW permission */
        addr = mmap(NULL, 4096, PROT_READ | PROT_WRITE,
                   MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);

        if (addr == MAP_FAILED) {
                printf("mmap failed!\n");
                TEST_END(__func__);
                exit(1);
        }

        printf("Initial mapping at: %p\n", addr);

        /* Write to memory */
        ptr = (int *)addr;
        *ptr = 0x12345678;
        printf("Wrote: 0x%x\n", *ptr);

        /* Change to read-only */
        ret = mprotect(addr, 4096, PROT_READ);
        if (ret != 0) {
                printf("mprotect failed!\n");
                munmap(addr, 4096);
                TEST_END(__func__);
                exit(1);
        }

        printf("Changed to read-only\n");

        /* Try to write (should cause SIGSEGV) */
        if (sigsetjmp(jump_buffer, 1) == 0) {
                printf("Attempting to write to read-only memory...\n");
                *ptr = 0xFFFFFFFF;  /* This should fault */

                /* If we get here, mprotect didn't work */
                printf("ERROR: Write to read-only succeeded (mprotect not working!)\n");
                munmap(addr, 4096);
                TEST_END(__func__);
                exit(1);
        } else {
                /* We caught the SIGSEGV, which is expected */
                printf("SIGSEGV caught as expected\n");
                printf("mprotect test: PASSED\n");
        }

        /* Clean up */
        munmap(addr, 4096);

        TEST_END(__func__);
}

static void test_mprotect_write_only(void)
{
        TEST_START(__func__);

        void *addr;
        volatile int *ptr;
        int ret;

        /* Map a page with RW permission */
        addr = mmap(NULL, 4096, PROT_READ | PROT_WRITE,
                   MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);

        if (addr == MAP_FAILED) {
                printf("mmap failed!\n");
                TEST_END(__func__);
                exit(1);
        }

        /* Write initial value */
        ptr = (int *)addr;
        *ptr = 0xDEADBEEF;
        printf("Initial value: 0x%x\n", *ptr);

        /* Change to write-only (unusual but valid) */
        ret = mprotect(addr, 4096, PROT_WRITE);
        if (ret != 0) {
                printf("mprotect to write-only failed (may not be supported)\n");
                munmap(addr, 4096);
                TEST_END(__func__);
                return;  /* Not necessarily a failure */
        }

        printf("Changed to write-only\n");

        /* Note: We can't easily test write-only without causing issues */
        printf("mprotect write-only test: PASSED (supported)\n");

        /* Clean up */
        munmap(addr, 4096);

        TEST_END(__func__);
}

int main(void)
{
        test_mprotect_read_only();
        test_mprotect_write_only();

        printf("All mprotect tests PASSED!\n");

        return 0;
}
